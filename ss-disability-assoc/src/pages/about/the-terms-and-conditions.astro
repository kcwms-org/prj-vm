---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'the-terms-and-conditions');
if (!entry) throw new Error('Missing content entry: pages/the-terms-and-conditions');
const { Content } = await render(entry);
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
  <section class="bg-brand-900 text-white py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">{entry.data.title}</h1>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 py-16 prose prose-gray max-w-none">
    <Content />
  </section>
</BaseLayout>
