---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'online-appointments');
if (!entry) throw new Error('Missing content entry: pages/online-appointments');
const { Content } = await render(entry);
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
  <section class="bg-brand-900 text-white py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Request a Free Consultation</h1>
      <p class="text-brand-100 text-lg">Free initial consultation and evaluation — no obligation.</p>
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-4 py-16 prose prose-gray max-w-none text-center">
    <Content />
  </section>
</BaseLayout>
