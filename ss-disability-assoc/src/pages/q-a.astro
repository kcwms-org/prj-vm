---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const faqEntries = (await getCollection("faqs")).sort(
  (a, b) => a.data.order - b.data.order,
);
const faqs = await Promise.all(
  faqEntries.map(async (entry) => ({
    question: entry.data.question,
    Content: (await render(entry)).Content,
  })),
);
---

<BaseLayout
  title="Q & A"
  description="Common questions about Social Security disability benefits answered by SS Disability Associates, LLC."
>
  <section class="bg-brand-900 text-white py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Common Questions</h1>
      <p class="text-brand-100 text-lg">
        Don't assume an unfavorable outcome. Let us help you.
      </p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 py-16 space-y-6">
    {
      faqs.map(({ question, Content }) => (
        <details class="group border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 bg-gray-50 hover:bg-gray-100 transition-colors font-semibold text-brand-900">
            {question}
            <svg
              class="w-5 h-5 flex-shrink-0 ml-4 transition-transform group-open:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </summary>
          <div class="px-6 py-4 text-gray-700 leading-relaxed prose prose-gray max-w-none">
            <Content />
          </div>
        </details>
      ))
    }
  </section>

  <section class="bg-gray-50 py-12 px-4 text-center">
    <p class="text-gray-600 mb-4">Have more questions? We're here to help.</p>
    <a
      href="/online-appointments"
      class="inline-block bg-brand-700 text-white font-semibold px-6 py-3 rounded-lg hover:bg-brand-900 transition-colors"
    >
      Book a Free Consultation
    </a>
  </section>
</BaseLayout>
