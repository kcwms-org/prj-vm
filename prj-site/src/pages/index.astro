---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Home" description="SS Disability Associates, LLC — Helping individuals file for and obtain Social Security disability benefits.">
  <!-- Hero -->
  <section class="bg-brand-900 text-white py-24 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">SS Disability Associates, LLC</h1>
      <p class="text-xl text-brand-100 mb-8">
        Our objective is to assist individuals with filing for, and obtaining all types of Social Security benefits.
      </p>
      <a href="/online-appointments" class="inline-block bg-white text-brand-900 font-semibold px-8 py-3 rounded-lg hover:bg-brand-100 transition-colors">
        Request a Free Consultation
      </a>
    </div>
  </section>

  <!-- Vision -->
  <section class="max-w-4xl mx-auto px-4 py-16 text-center">
    <h2 class="text-3xl font-bold text-brand-900 mb-4">Vision of SS Disability Associates, LLC</h2>
    <p class="text-lg text-gray-600 mb-6">
      With over 30+ years of experience with Social Security programs, we help individuals pursue and obtain the benefits due to them.
    </p>
    <p class="text-lg text-gray-600">
      Have you been denied Social Security disability benefits? You have the right to file an appeal regarding the decision made.
      <strong class="text-brand-700"> Contact us today for a free initial consultation.</strong>
    </p>
  </section>

  <!-- Services -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-900 text-center mb-10">How We Can Help</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { title: 'Review & Evaluate', body: 'We review and evaluate your disability claim to build the strongest possible case.' },
          { title: 'Apply & Appeal', body: 'Assist with Social Security applications and appeals when claims are denied.' },
          { title: "Children's Benefits", body: "Claim benefits for children who are disabled or who qualify under a disabled parent." },
        ].map(({ title, body }) => (
          <div class="bg-white rounded-xl shadow p-6">
            <h3 class="font-semibold text-brand-800 text-lg mb-2">{title}</h3>
            <p class="text-gray-600 text-sm">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 text-center">
    <h2 class="text-2xl font-bold text-brand-900 mb-4">Ready to get started?</h2>
    <p class="text-gray-600 mb-6">Don't navigate the Social Security system alone. Let us help you.</p>
    <a href="/online-appointments" class="inline-block bg-brand-700 text-white font-semibold px-8 py-3 rounded-lg hover:bg-brand-900 transition-colors">
      Book Your Free Consultation
    </a>
  </section>
</BaseLayout>
