---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Online Appointments" description="Request a free initial consultation with SS Disability Associates, LLC.">
  <section class="bg-brand-900 text-white py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Request a Free Consultation</h1>
      <p class="text-brand-100 text-lg">Free initial consultation and evaluation — no obligation.</p>
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-4 py-16 text-center space-y-6">
    <p class="text-lg text-gray-700">
      I work with and not against you, and for all those tough questions about Social Security Disability that keep you up
      at night pondering — STOP, and let me help you.
    </p>
    <p class="text-gray-600">Don't waste another minute trying to figure it out on your own.</p>
    <p class="text-gray-600 font-semibold">Request your free initial consult today. Mark those calendars — because time is precious.</p>

    <div class="pt-6 border-t border-gray-200 space-y-3 text-gray-700">
      <p class="font-semibold text-brand-900">Contact us to schedule:</p>
      <p><a href="tel:2053361771" class="text-brand-700 hover:underline text-lg font-medium">205-336-1771</a></p>
      <p><a href="mailto:vmanear@ssdisabilityassoc.com" class="text-brand-700 hover:underline">vmanear@ssdisabilityassoc.com</a></p>
    </div>
  </section>
</BaseLayout>
