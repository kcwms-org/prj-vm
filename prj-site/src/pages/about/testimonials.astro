---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Testimonials" description="Read what clients say about SS Disability Associates, LLC.">
  <section class="bg-brand-900 text-white py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Testimonials</h1>
      <p class="text-brand-100 text-lg">We want to hear your story.</p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 py-16 text-center">
    <p class="text-gray-600 mb-8 text-lg">
      We want to hear your story and how SS Disability Associates, LLC has helped you. Client testimonials will appear here.
    </p>
    <a href="/online-appointments" class="inline-block bg-brand-700 text-white font-semibold px-6 py-3 rounded-lg hover:bg-brand-900 transition-colors">
      Share Your Story
    </a>
  </section>
</BaseLayout>
