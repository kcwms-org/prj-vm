---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Contacts" description="Contact SS Disability Associates, LLC — Birmingham, AL.">
  <section class="bg-brand-900 text-white py-16 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Contacts</h1>
      <p class="text-brand-100 text-lg">We're here to help. Reach out today.</p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 py-16 grid grid-cols-1 md:grid-cols-2 gap-10">
    <div class="space-y-4">
      <h2 class="text-xl font-bold text-brand-900">Office Information</h2>
      <div class="text-gray-700 space-y-2">
        <p><strong>Address</strong></p>
        <p>413 16th Street North<br />Birmingham, AL 35203</p>
        <p class="pt-2"><strong>Phone</strong></p>
        <p><a href="tel:2053361771" class="text-brand-700 hover:underline">205-336-1771</a></p>
        <p class="pt-2"><strong>Email</strong></p>
        <p><a href="mailto:vmanear@ssdisabilityassoc.com" class="text-brand-700 hover:underline">vmanear@ssdisabilityassoc.com</a></p>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="text-xl font-bold text-brand-900">Schedule a Consultation</h2>
      <p class="text-gray-600">Ready to get started? Request a free initial consultation and evaluation.</p>
      <a href="/online-appointments" class="inline-block bg-brand-700 text-white font-semibold px-6 py-3 rounded-lg hover:bg-brand-900 transition-colors">
        Book Online
      </a>
    </div>
  </section>
</BaseLayout>
